{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/main/.schema/devbox.schema.json",
  "packages": [
    "cmake@latest",
    "ninja@latest",
    "pkg-config@latest",
    "python311@latest",
    "path:.#boostPython"
  ],
  "shell": {
    "init_hook": [
      "export PATH=\"$(readlink -f \"${DEVBOX_PROJECT_ROOT}/.devbox/nix/profile/default\")/bin:${PATH}\"",
      "echo 'Quassimodo dev shell (isolated). cmake: '$(command -v cmake)"
    ]
  }
}
